{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.1.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 1,
      "title": "API Request Rate (req/s)",
      "type": "graph",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{ method }} {{ endpoint }}"
        }
      ]
    },
    {
      "id": 2,
      "title": "API Error Rate (%)",
      "type": "stat",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~'5..'}[5m]) / rate(http_requests_total[5m]) * 100",
          "legendFormat": "Error Rate %"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "API P95 Latency (seconds)",
      "type": "graph",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P95 Latency"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Recommendations",
      "type": "stat",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "targets": [
        {
          "expr": "recommendation_requests_total",
          "legendFormat": "Total Recommendations"
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU Usage per Pod",
      "type": "graph",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace='recommendation'}[1m])",
          "legendFormat": "{{ pod }}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Memory Usage per Pod (MiB)",
      "type": "graph",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{namespace='recommendation'} / 1024 / 1024",
          "legendFormat": "{{ pod }}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Pod Restarts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 21 },
      "targets": [
        {
          "expr": "kube_pod_container_status_restarts_total{namespace='recommendation'}",
          "legendFormat": "{{ pod }}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Recommendation Response Time (P99)",
      "type": "graph",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 21 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(recommendation_response_seconds_bucket[5m]))",
          "legendFormat": "P99 Response Time"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": ["mlops", "recommendation", "api"],
  "title": "E-Commerce Recommendation Platform",
  "uid": "ecommerce-rec-dashboard",
  "version": 1
}
